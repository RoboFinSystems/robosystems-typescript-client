{
  "name": "@robosystems/client",
  "version": "0.3.19",
  "description": "TypeScript client library for RoboSystems Financial Knowledge Graph API",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "create-feature": "./bin/create-feature.sh"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./clients": {
      "types": "./artifacts/index.d.ts",
      "require": "./artifacts/index.js",
      "import": "./artifacts/index.js",
      "default": "./artifacts/index.js"
    },
    "./ledger": {
      "types": "./artifacts/LedgerClient.d.ts",
      "require": "./artifacts/LedgerClient.js",
      "import": "./artifacts/LedgerClient.js",
      "default": "./artifacts/LedgerClient.js"
    },
    "./investor": {
      "types": "./artifacts/InvestorClient.d.ts",
      "require": "./artifacts/InvestorClient.js",
      "import": "./artifacts/InvestorClient.js",
      "default": "./artifacts/InvestorClient.js"
    },
    "./library": {
      "types": "./artifacts/LibraryClient.d.ts",
      "require": "./artifacts/LibraryClient.js",
      "import": "./artifacts/LibraryClient.js",
      "default": "./artifacts/LibraryClient.js"
    },
    "./agent": {
      "types": "./artifacts/AgentClient.d.ts",
      "require": "./artifacts/AgentClient.js",
      "import": "./artifacts/AgentClient.js",
      "default": "./artifacts/AgentClient.js"
    },
    "./query": {
      "types": "./artifacts/QueryClient.d.ts",
      "require": "./artifacts/QueryClient.js",
      "import": "./artifacts/QueryClient.js",
      "default": "./artifacts/QueryClient.js"
    },
    "./operations": {
      "types": "./artifacts/OperationClient.d.ts",
      "require": "./artifacts/OperationClient.js",
      "import": "./artifacts/OperationClient.js",
      "default": "./artifacts/OperationClient.js"
    },
    "./client": {
      "types": "./client.gen.d.ts",
      "require": "./client.gen.js",
      "import": "./client.gen.js",
      "default": "./client.gen.js"
    },
    "./types": {
      "types": "./types.gen.d.ts",
      "require": "./types.gen.js",
      "import": "./types.gen.js",
      "default": "./types.gen.js"
    },
    "./sdk": {
      "types": "./sdk.gen.d.ts",
      "require": "./sdk.gen.js",
      "import": "./sdk.gen.js",
      "default": "./sdk.gen.js"
    }
  },
  "files": [
    "index.js",
    "index.ts",
    "index.d.ts",
    "client.gen.js",
    "client.gen.ts",
    "client.gen.d.ts",
    "sdk.gen.js",
    "sdk.gen.ts",
    "sdk.gen.d.ts",
    "types.gen.js",
    "types.gen.ts",
    "types.gen.d.ts",
    "client/**/*",
    "core/**/*",
    "artifacts/**/*",
    "sdk/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate": "npm run generate:clean && npm run generate:sdk && npm run generate:fix && npm run generate:graphql && npm run prepare:publish && npm run format && npm run lint:fix",
    "generate:clean": "rm -rf sdk clients/graphql/generated",
    "generate:sdk": "npx @hey-api/openapi-ts -f openapi-ts.config.js",
    "generate:graphql": "npx graphql-codegen --config codegen.ts",
    "generate:fix": "node scripts/fix-sdk-types.js",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "validate": "npm run validate:fix && npm run lint && npm run typecheck",
    "feature:create": "./bin/create-feature.sh",
    "release:create": "./bin/create-release.sh",
    "pr:create": "./bin/create-pr.sh",
    "validate:fix": "npm run format && npm run lint:fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "npm run validate && npm run test && npm run build",
    "prepare:publish": "node prepare.js",
    "prepublishOnly": "npm run prepare:publish",
    "build": "tsc"
  },
  "keywords": [
    "robosystems",
    "financial",
    "graph",
    "api",
    "sdk",
    "typescript",
    "knowledge-graph"
  ],
  "author": "RFS LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RoboFinSystems/robosystems-typescript-client.git"
  },
  "bugs": {
    "url": "https://github.com/RoboFinSystems/robosystems-typescript-client/issues"
  },
  "homepage": "https://github.com/RoboFinSystems/robosystems-typescript-client#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@graphql-codegen/cli": "^6.3.0",
    "@graphql-codegen/typed-document-node": "^6.1.8",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@hey-api/openapi-ts": "^0.91.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "happy-dom": "^20.0.8",
    "prettier": "^3.0.0",
    "prettier-plugin-organize-imports": "^4.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0"
  }
}
